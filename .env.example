# 空教室查询系统 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== 教务系统配置 ====================

# 教务系统账号（必填）
QFNU_USERNAME=你的学号

# 教务系统密码（必填）
QFNU_PASSWORD=你的密码

# 待查询的教学楼，多个用逗号分隔（必填）
QFNU_BUILDINGS=综合教学楼,JS,生物楼,文史楼,老文史楼,格物楼,致知楼

# ==================== Flask 服务配置 ====================

# 服务监听地址（可选，默认 0.0.0.0）
FLASK_HOST=0.0.0.0

# 服务端口（可选，默认 5000）
FLASK_PORT=5000

# 是否开启调试模式（可选，默认 false）
FLASK_DEBUG=false
