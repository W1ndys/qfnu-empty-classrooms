# 空教室查询系统 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== 教务系统配置 ====================

# 教务系统账号（必填）
QFNU_USERNAME=你的学号

# 教务系统密码（必填）
QFNU_PASSWORD=你的密码

# ==================== 高级模式配置 ====================

# 是否使用高级API模式（可选，默认 false）
# 高级模式使用教务系统的 jsjy_query2 接口直接查询空闲教室
# 该模式需要账号有相应权限（通常是教师或管理员账号）
# 设置为 true 时，将使用高级接口，查询更快且结果更准确
USE_ADVANCED_API=false

# ==================== Flask 服务配置 ====================

# 服务监听地址（可选，默认 0.0.0.0）
FLASK_HOST=0.0.0.0

# 服务端口（可选，默认 5000）
FLASK_PORT=5000

# 是否开启调试模式（可选，默认 false）
FLASK_DEBUG=false

# ==================== 安全配置 ====================

# Flask Session 密钥（必填，用于加密 Session）
# 请使用随机字符串，可通过以下命令生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this

# 管理员密码（必填，用于后台管理面板登录）
# 首次登录后可在后台修改
ADMIN_PASSWORD=admin123

# 是否开启前端访问验证（可选，默认 false）
# 开启后用户访问前端页面需要输入密码
ENABLE_FRONTEND_AUTH=false

# 前端访问密码（当 ENABLE_FRONTEND_AUTH=true 时需要设置）
# 也可在后台管理面板中设置
FRONTEND_PASSWORD=

# ==================== 通知配置 ====================

# 飞书 Webhook URL（可选）
# 配置后服务启动时会发送通知
# 获取方式：飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人 -> 复制 Webhook 地址
FEISHU_WEBHOOK_URL=
